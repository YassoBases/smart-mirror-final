# Backend API URL — set this when your backend server is running
# REACT_APP_API_URL=http://localhost:3000

# Set to true to show demo emails in the Gmail widget (no backend needed)
REACT_APP_GMAIL_USE_MOCK=true

# ── Wardrobe feature (docker-compose) ─────────────────────────────────────────
# The backend service loads these from backend/.env (gitignored). Copy
# backend/.env.example -> backend/.env and fill in. Placeholders only here:
#
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# REPLICATE_API_TOKEN=
# REPLICATE_VTON_MODEL=
# PUBLIC_BASE_URL=            # ngrok https URL so Replicate can fetch images
# OWM_API_KEY=
# HOME_LAT=
# HOME_LNG=
# BLIP2_ENDPOINT_URL=
# BLIP2_ENDPOINT_TOKEN=
# BG_REMOVER_URL=http://bg_remover:8001   # set to compose service names
# PREF_RANKER_URL=http://pref_ranker:8002
